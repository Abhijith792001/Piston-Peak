rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'abhijith792001@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'brand', 'price', 'description', 'imageUrl', 'stock', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.name is string && data.name.size() <= 200 &&
             data.brand is string && data.brand.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 1000 &&
             data.imageUrl is string && data.imageUrl.size() <= 500 &&
             data.stock is int && data.stock >= 0 &&
             data.createdAt is timestamp;
    }

    // --- Collection Routes ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user' && incoming().createdAt == request.time;
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    (isAdmin() || incoming().role == existing().role);
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt == request.time;
    }

    // Orders Collection
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isAdmin();
    }
  }
}
